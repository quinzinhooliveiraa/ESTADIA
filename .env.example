# ── Database ────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:pass@host:5432/dbname

# ── Session ─────────────────────────────────────────────────────────────────
SESSION_SECRET=change-me-to-a-long-random-string

# ── CORS (A5) ────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins in production.
# Leave unset in development (all origins allowed).
APP_ORIGIN=https://estadia.app,https://www.estadia.app

# ── AbacatePay ────────────────────────────────────────────────────────────────
# AbacatePay usa chaves separadas por versão de API.
#
# Chave v1 — usada nos endpoints /v1/pixQrCode/* (PIX avulso, QR code único).
# Sem essa variável, o método "PIX avulso" fica indisponível.
ABACATEPAY_API_KEY_V1=
#
# Chave v2 — usada nos endpoints /v2/products/* e /v2/subscriptions/*
# (cartão de crédito e PIX Automático recorrente).
# Permissões mínimas: CHECKOUT:CREATE, PRODUCT:CREATE, PRODUCT:READ
# Sem essa variável, cartão e PIX automático ficam indisponíveis.
ABACATEPAY_API_KEY=

# Secret do webhook configurado no dashboard AbacatePay.
# AbacatePay v2 assina o payload com HMAC-SHA256 + base64 no header X-Webhook-Signature.
ABACATEPAY_WEBHOOK_SECRET=

# IDs dos produtos criados no dashboard AbacatePay (com cycle=MONTHLY / ANNUALLY).
# Se não informados, o app cria os produtos automaticamente via API no primeiro checkout.
# Permissão necessária para criação: PRODUCT:CREATE
ABACATEPAY_PRODUCT_ID_MENSAL=
ABACATEPAY_PRODUCT_ID_ANUAL=

# Métodos de pagamento aceitos nas assinaturas: PIX e/ou CARD (separados por vírgula).
# PIX requer "PIX Automático" habilitado no dashboard AbacatePay.
# Padrão: PIX
ABACATEPAY_METHODS=PIX

# ── SMS / OTP provider (Twilio) ───────────────────────────────────────────────
# When all three TWILIO_* vars are set, OTPs are sent via SMS.
# Without them, codes are logged to console (development only).
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token
TWILIO_FROM_NUMBER=+15550000000

# ── Admin panel ───────────────────────────────────────────────────────────────
# Comma-separated E.164 phone numbers that get is_admin=true on next login.
# Example: ADMIN_TELEFONES=+5511999990000,+5521999990001
ADMIN_TELEFONES=

# ── Node environment ─────────────────────────────────────────────────────────
NODE_ENV=development

# ── Frontend (Vite) ──────────────────────────────────────────────────────────
# D5: set to "true" to show the demo login button
VITE_DEMO_MODE=false
