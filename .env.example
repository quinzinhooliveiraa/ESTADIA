# ── Database ────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:pass@host:5432/dbname

# ── Session ─────────────────────────────────────────────────────────────────
SESSION_SECRET=change-me-to-a-long-random-string

# ── CORS (A5) ────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins in production.
# Leave unset in development (all origins allowed).
APP_ORIGIN=https://estadia.app,https://www.estadia.app

# ── AbacatePay (pagamentos PIX) ──────────────────────────────────────────────
ABACATEPAY_API_KEY=
# Secret sent in every AbacatePay webhook request header (A2: required in production)
ABACATEPAY_WEBHOOK_SECRET=
# Set to "true" to verify billing status via AbacatePay API before activating subscription
ABACATEPAY_LIVE=false

# ── SMS / OTP provider (Twilio) ───────────────────────────────────────────────
# When all three TWILIO_* vars are set, OTPs are sent via SMS.
# Without them, codes are logged to console (development only).
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token
TWILIO_FROM_NUMBER=+15550000000

# ── Admin panel ───────────────────────────────────────────────────────────────
# Comma-separated E.164 phone numbers that get is_admin=true on next login.
# Example: ADMIN_TELEFONES=+5511999990000,+5521999990001
ADMIN_TELEFONES=

# ── Node environment ─────────────────────────────────────────────────────────
NODE_ENV=development

# ── Frontend (Vite) ──────────────────────────────────────────────────────────
# D5: set to "true" to show the demo login button
VITE_DEMO_MODE=false
