# Database (Replit PostgreSQL — provisioned automatically)
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Session security — generate with: openssl rand -hex 32
SESSION_SECRET=replace-with-random-secret

# AbacatePay PIX integration
ABACATEPAY_API_KEY=
ABACATEPAY_WEBHOOK_SECRET=   # token configured in AbacatePay dashboard → Webhooks

# Set to "true" to enable live billing verification on the webhook
# When false (default), the webhook trusts the event payload without re-querying AbacatePay
ABACATEPAY_LIVE=false

# Set to "true" to allow the /auth/demo endpoint in production
# Leave unset or "false" to block it (recommended for production)
DEMO_MODE=false

# Runtime environment
NODE_ENV=development
PORT=8080
